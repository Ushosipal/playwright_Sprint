{
  "name": "parabank-capstone",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright framework for ParaBank fund-transfer validation (Capstone)",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:e2e": "playwright test tests/e2e",
    "test:perf": "playwright test tests/performance",
    "type-check": "tsc --noEmit",
    "report:allure:generate": "allure generate test-results/allure-results --clean -o test-results/allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.10.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^2.15.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0",
    "winston": "^3.11.0"
  },
  "engines": {
    "node": ">=18"
  }
}