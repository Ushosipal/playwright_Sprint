pipeline {
    agent any

    options {
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20', daysToKeepStr: '14'))
        disableConcurrentBuilds()
    }

    environment {
        CI = 'true'
        NODE_OPTIONS = '--max-old-space-size=4096'
        PW_WORKERS = '1'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup') {
            steps {
                bat 'node --version'
                bat 'npm --version'
                bat 'npm ci'
                bat 'npx playwright install chromium'
            }
        }

        stage('Type Check') {
            steps {
                bat 'npm run type-check'
            }
        }

        stage('UI Tests') {
            steps {
                bat 'npm run test:ui'
            }
        }

        stage('API Tests') {
            steps {
                bat 'npm run test:api'
            }
        }

        stage('E2E Hybrid') {
            steps {
                bat 'npm run test:e2e'
            }
        }

        stage('Performance Lite') {
            steps {
                bat 'npm run test:perf'
            }
        }

        stage('Generate Allure Report') {
            steps {
                bat 'npm run report:allure:generate'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'test-results/**/*', allowEmptyArchive: true
            junit testResults: 'test-results/junit.xml', allowEmptyResults: true
        }
    }
}