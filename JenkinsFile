pipeline {
    agent any

    options {
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20', daysToKeepStr: '14'))
        disableConcurrentBuilds()
    }

    environment {
        CI = 'true'
        NODE_OPTIONS = '--max-old-space-size=4096'
        PW_WORKERS = '1'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup') {
            steps {
                sh '''
                    node --version
                    npm --version
                    npm ci
                    npx playwright install --with-deps chromium
                '''
            }
        }

        stage('Type Check') {
            steps {
                sh 'npm run type-check'
            }
        }

        stage('UI Tests') {
            steps {
                sh 'npm run test:ui || true'
            }
        }

        stage('API Tests') {
            steps {
                sh 'npm run test:api || true'
            }
        }

        stage('E2E Hybrid') {
            steps {
                sh 'npm run test:e2e || true'
            }
        }

        stage('Performance Lite') {
            steps {
                sh 'npm run test:perf || true'
            }
        }

        stage('Generate Allure Report') {
            steps {
                sh 'npm run report:allure:generate || true'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'test-results/**/*', allowEmptyArchive: true
            junit testResults: 'test-results/junit.xml', allowEmptyResults: true
        }
    }
}